{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@optigestor/validators": ["packages/validators/src"],
      "@optigestor/types": ["packages/types/src"],
      "@optigestor/utils": ["packages/utils/src"],
      "@optigestor/db": ["packages/db/src"]
    }
  }
}
