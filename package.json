{
  "name": "optigestor",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @optigestor/db db:generate",
    "db:migrate": "pnpm --filter @optigestor/db db:migrate",
    "db:studio": "pnpm --filter @optigestor/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
